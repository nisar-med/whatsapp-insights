{
  "name": "whatsapp-insights",
  "version": "0.3.1",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "whatsapp-insights": "dist/server.js"
  },
  "files": [
    "dist",
    ".next",
    "app",
    "public",
    "next.config.mjs",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "dev": "WHATSAPP_INSIGHTS_DEV=true tsx watch server.ts",
    "build": "next build",
    "build:app": "next build",
    "build:server": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.server.json",
    "start": "node server.ts",
    "prepublishOnly": "npm run build:app && npm run build:server",
    "test": "npm run lint",
    "lint": "eslint .",
    "clean": "next clean"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@hookform/resolvers": "^5.2.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-react": "^0.553.0",
    "motion": "^12.34.3",
    "next": "^15.4.9",
    "pino": "^10.3.1",
    "postcss": "^8.5.6",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "9.39.1",
    "eslint-config-next": "16.0.8",
    "firebase-tools": "^15.0.0",
    "tailwindcss": "4.1.11",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
